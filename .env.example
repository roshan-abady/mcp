# Example environment for MCP Snowflake Server
# Copy to .env and fill in real values.

# Required
SNOWFLAKE_USER="your.name@company.com"
SNOWFLAKE_ACCOUNT="your_account_identifier"  # e.g. bu20658.ap-southeast-2
SNOWFLAKE_ROLE="your_role"
SNOWFLAKE_DATABASE="your_database"
SNOWFLAKE_SCHEMA="your_schema"
SNOWFLAKE_WAREHOUSE="your_warehouse"
SNOWFLAKE_AUTHENTICATOR="externalbrowser"   # or snowflake, oauth, etc.
SNOWFLAKE_INSECURE_MODE="false"              # set to "true" only if needed

# Optional
SNOWFLAKE_HOST=""                             # override host if required
SERVICE_CONFIG_FILE="services/tools_config.yaml"
